---
export interface Props {
  src: string;
  alt: string;
  camera: string;
  film: string;
  children?: unknown;
}
const { src, alt, camera, film, children } = Astro.props;
---

<div
  class="photo-outer-frame"
  data-photo-frame
  data-photo-src={src}
  data-photo-alt={alt}
  data-photo-camera={camera}
  data-photo-film={film}
>
  <div class="photo-side-text photo-side-left">
    <span class="side-text">{camera}</span>
  </div>
  <div class="photo-frame">
    <div class="photo-image-wrapper">
      {
        children ? (
          children
        ) : (
          <img
            src={src}
            alt={alt}
            loading="lazy"
            class="photo-image"
            data-photo-image
          />
        )
      }
    </div>
  </div>
  <div class="photo-side-text photo-side-right">
    <span class="side-text">{film}</span>
  </div>
</div>

<style>
  .photo-outer-frame {
    position: relative;
    display: flex;
    align-items: stretch;
    justify-content: center;
    height: 100%;
    width: 100%;
    padding: 0 2.5rem;
    box-sizing: border-box;
    cursor: pointer;
  }
  .photo-frame {
    flex: 1 1 auto;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    height: 100%;
    width: 100%;
    background: white;
    border-radius: 0;
    box-shadow: none;
    overflow: visible;
    padding: 0;
    position: relative;
  }
  .photo-side-left,
  .photo-side-right {
    position: absolute;
    width: 2.5rem;
    display: flex;
    align-items: center;
    height: 100%;
    opacity: 0;
    transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .photo-outer-frame:hover .photo-side-left,
  .photo-outer-frame:hover .photo-side-right {
    opacity: 1;
  }
  .photo-side-left {
    left: 0;
    align-items: end;
    justify-content: right;
  }
  .photo-side-right {
    right: 0;
    align-items: start;
    justify-content: left;
  }
  .side-text {
    display: block;
    color: #222;
    font-size: 1rem;
    font-family: 'Hack', 'Hack Regular', monospace;
    letter-spacing: 0.1em;
    font-weight: 500;
    white-space: nowrap;
    text-align: center;
    user-select: text;
    background: transparent;
    padding: 0;
    margin: 0;
  }
  .photo-side-left .side-text {
    transform: rotate(-90deg) translate(100%, 0);
    transform-origin: bottom right;
  }
  .photo-side-right .side-text {
    transform: rotate(90deg) translate(0, -100%);
    transform-origin: top left;
  }
  .photo-image-wrapper {
    flex: 1 1 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    min-width: 0;
  }
  .photo-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 0;
    box-shadow: none;
  }
</style>
