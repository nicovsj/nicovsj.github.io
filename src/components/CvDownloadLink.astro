---
import { useTranslations } from '../i18n/utils';
import cvMeta from '../data/cv-meta.json';

const CV_URL = '/cv.pdf';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as 'en' | 'fr');
const lastUpdated = cvMeta.publishedAt ?? t('cv.unknown');
---

<div class="cv-download">
  <a href={CV_URL} target="_blank" rel="noopener noreferrer" class="cv-link">
    {t('cv.link')}
  </a>
  <span class="cv-meta">
    {t('cv.updated')}
    <span>{lastUpdated}</span>
  </span>
</div>

<style>
  .cv-download {
    margin-top: 0.5rem;
  }

  .cv-link {
    font-size: 1.2rem;
  }

  .cv-meta {
    margin-left: 0.5rem;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }
</style>
