---
import { useTranslations } from '../i18n/utils';
import {
  publications,
  type Publication,
  type PublicationCategory,
} from '../data/publications';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as 'en' | 'fr');

const categories: PublicationCategory[] = ['conference', 'demo'];
const categoryTitleKeys = {
  conference: 'publications.conference',
  demo: 'publications.demo',
} as const;
---

<div class="publications">
  <div class="publications-header">
    <h2>{t('publications.title')}</h2>
    <a href="/publications.bib" class="bibtex-link">
      {t('publications.bibtex')}
    </a>
  </div>

  {
    categories.map(category => (
      <>
        <h3>{t(categoryTitleKeys[category])}</h3>
        <ol>
          {publications[category].map((paper: Publication) => (
            <li>
              <a href={paper.url} target="_blank">
                <strong>{paper.title}</strong>
              </a>
              <ul>
                <li>
                  {paper.authors.map((author, index) => (
                    <>
                      {index > 0 &&
                        (index === paper.authors.length - 1
                          ? ` ${t('publications.and')} `
                          : ', ')}
                      {author.isSelf ? (
                        <strong>{author.name}</strong>
                      ) : (
                        author.name
                      )}
                    </>
                  ))}
                </li>
                <li>
                  <em>{paper.venue}</em>
                </li>
                {paper.links?.map(link => (
                  <li>
                    <a href={link.url} target="_blank">
                      {t(link.labelKey)}
                    </a>
                  </li>
                ))}
              </ul>
            </li>
          ))}
        </ol>
      </>
    ))
  }
</div>

<style>
  .publications {
    margin-top: 2rem;
  }

  .publications-header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem 1rem;
    margin-bottom: 1rem;
  }

  .publications-header h2 {
    margin-bottom: 0;
  }

  .bibtex-link {
    font-size: 0.95rem;
  }

  .publications h3 {
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .publications ol {
    margin-left: 1.5rem;
  }

  .publications ul {
    margin-left: 1.5rem;
    margin-top: 0.25rem;
  }

  .publications li {
    margin-bottom: 0.5rem;
  }
</style>
