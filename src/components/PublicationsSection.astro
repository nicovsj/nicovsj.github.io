---
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang as 'en' | 'fr');
const isFr = lang === 'fr';
---

<div class="publications">
  <h2>{t('publications.title')}</h2>

  <h3>{t('publications.conference')}</h3>
  <ol>
    <li>
      <a href="https://doi.org/10.14778/3611479.3611488" target="_blank">
        <strong>REmatch: A Novel Regex Engine for Finding All Matches</strong>
      </a>
      <ul>
        <li>
          Cristian Riveros, <strong>Nicolás Van Sint Jan</strong>
          {isFr ? 'et' : 'and'} Domagoj Vrgoč
        </li>
        <li>
          <em>Proceedings of the VLDB Endowment (VLDB'23)</em>, pages 2792-2804
        </li>
        <li>
          <a href="https://github.com/REmatchChile/REmatch" target="_blank">
            {isFr ? 'Dépôt REmatch sur GitHub' : 'REmatch repository on GitHub'}
          </a>
        </li>
      </ul>
    </li>
  </ol>

  <h3>{t('publications.demo')}</h3>
  <ol>
    <li>
      <a href="https://doi.org/10.1145/3626246.3654746" target="_blank">
        <strong
          >Demostrating REmatch: A Novel Regex Engine for Finding All Matches</strong
        >
      </a>
      <ul>
        <li>
          Kyle Bossoney, Vicente Calisto, Cristian Riveros, Gustavo Toro, <strong
            >Nicolás Van Sint Jan</strong
          >
          {isFr ? 'et' : 'and'} Domagoj Vrgoč
        </li>
        <li>
          <em
            >Companion of the 2024 International Conference on Management of
            Data (SIGMOD'24)</em
          >, pages 448-451
        </li>
      </ul>
    </li>
  </ol>
</div>

<style>
  .publications {
    margin-top: 2rem;
  }

  .publications h2 {
    margin-bottom: 1rem;
  }

  .publications h3 {
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .publications ol {
    margin-left: 1.5rem;
  }

  .publications ul {
    margin-left: 1.5rem;
    margin-top: 0.25rem;
  }

  .publications li {
    margin-bottom: 0.5rem;
  }
</style>
