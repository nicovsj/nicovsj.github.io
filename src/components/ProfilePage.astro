---
import Layout from '../layouts/Layout.astro';
import ContactSection from './ContactSection.astro';
import PublicationsSection from './PublicationsSection.astro';
import CvDownloadLink from './CvDownloadLink.astro';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: 'en' | 'fr';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<Layout title="Nicolás Van Sint Jan" description={t('meta.description')}>
  <article class="indent-pars">
    <div class="profile">
      <div class="profile-image">
        <img src="/images/selfie.jpg" alt="Nicolás Van Sint Jan" />
      </div>
      <div class="profile-content">
        <div class="name">Nicolás Van Sint Jan</div>
        <div class="title">
          {t('profile.title')}{' '}
          <a href="https://www.irif.fr" target="_blank">IRIF</a>
        </div>
        <CvDownloadLink lang={lang} />
        <ContactSection lang={lang} />
      </div>
    </div>

    <div class="abstract">
      <h2>{t('abstract.title')}</h2>
      <p set:html={t('abstract.body')} />
    </div>

    <PublicationsSection lang={lang} />
  </article>
</Layout>

<style>
  .profile {
    display: flex;
    gap: 3rem;
    align-items: center;
    margin-bottom: 3rem;
  }

  .profile-image {
    flex-shrink: 0;
    width: 200px;
    height: 200px;
    overflow: hidden;
    border-radius: 50%;
    border: 1px solid var(--color-border);
  }

  .profile-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .profile-content {
    display: block;
    gap: 0.2rem;
  }

  .name {
    font-size: 1.8rem;
    font-weight: bold;
  }

  .title {
    font-size: 1.4rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .profile {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
