  {
    src: '/images/photography/Photo33_30.jpg',
    alt: 'Photo 13',
    camera: 'LEICA M6',
    film: 'KODAK PORTRA 400',
  },
];
---

<Layout
  title={t('photography.title')}
  description={t('photography.description')}
>
  <article class="photography-gallery">
    <header class="gallery-header">
      <h1>{t('photography.title')}</h1>
      <p>{t('photography.description')}</p>
    </header>

    <div class="photo-grid" id="photoGrid">
      {
        photos.map(photo => (
          <div class="photo-item">
            <PhotoOuterFrame
              src={photo.src}
              alt={photo.alt}
              camera={photo.camera}
              film={photo.film}
            />
          </div>
        ))
      }
    </div>

    <!-- Remove the lightbox modal and related CSS/JS -->
  </article>
</Layout>

<style>
  /* Remove component-specific styles now handled by PhotoOuterFrame.astro */
  /* Keep only grid, responsive, and general layout styles here. */

  .photography-gallery {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .gallery-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .gallery-header h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .gallery-header p {
    font-size: 1.2rem;
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 0 auto;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1rem;
    margin-bottom: 3rem;
  }
  .photo-item {
    opacity: 1;
    transform: scale(1);
    transition: all 0.3s ease;
    /* Remove grid-row span classes */
  }

  /* Responsive design */
  @media (max-width: 1200px) {
    .photo-grid {
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    }
  }

  @media (max-width: 768px) {
    .photo-grid {
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 0.75rem;
    }

    .gallery-header h1 {
      font-size: 2rem;
    }
  }

  @media (max-width: 480px) {
    .photo-grid {
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 0.5rem;
    }
  }
</style>

<!-- No <script> block needed -->
