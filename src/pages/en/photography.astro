---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import PhotoOuterFrame from '../../components/PhotoOuterFrame.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Sample photography data - you can replace this with your actual photos
const photos = [
  {
    src: '/images/photography/000030160003.jpg',
    alt: 'Photo 1',
    camera: 'LEICA M6',
    film: 'KODAK PORTRA 400',
  },
  {
    src: '/images/photography/000030160037.jpg',
    alt: 'Photo 2',
    camera: 'CANON AE-1',
    film: 'FUJIFILM PRO 400H',
  },
  {
    src: '/images/photography/000032390019.jpg',
    alt: 'Photo 3',
    camera: 'NIKON F3',
    film: 'ILFORD HP5 PLUS',
  },
  {
    src: '/images/photography/000032390021.jpg',
    alt: 'Photo 4',
    camera: 'HASSELBLAD 500C/M',
    film: 'KODAK EKTACHROME 100',
  },
  {
    src: '/images/photography/000032390029.jpg',
    alt: 'Photo 5',
    camera: 'PENTAX K1000',
    film: 'FUJIFILM VELVIA 50',
  },
  {
    src: '/images/photography/000032390031.jpg',
    alt: 'Photo 6',
    camera: 'OLYMPUS OM-1',
    film: 'KODAK TRI-X 400',
  },
  {
    src: '/images/photography/000032390034.jpg',
    alt: 'Photo 7',
    camera: 'LEICA M6',
    film: 'KODAK PORTRA 400',
  },
  {
    src: '/images/photography/000033720004.jpg',
    alt: 'Photo 8',
    camera: 'CANON AE-1',
    film: 'FUJIFILM PRO 400H',
  },
  {
    src: '/images/photography/000033720014.jpg',
    alt: 'Photo 9',
    camera: 'NIKON F3',
    film: 'ILFORD HP5 PLUS',
  },
  {
    src: '/images/photography/000033720016.jpg',
    alt: 'Photo 10',
    camera: 'HASSELBLAD 500C/M',
    film: 'KODAK EKTACHROME 100',
  },
  {
    src: '/images/photography/000033720018.jpg',
    alt: 'Photo 11',
    camera: 'PENTAX K1000',
    film: 'FUJIFILM VELVIA 50',
  },
  {
    src: '/images/photography/000033720033.jpg',
    alt: 'Photo 12',
    camera: 'OLYMPUS OM-1',
    film: 'KODAK TRI-X 400',
  },
  {
    src: '/images/photography/Photo33_30.jpg',
    alt: 'Photo 13',
    camera: 'LEICA M6',
    film: 'KODAK PORTRA 400',
  },
];
---

<Layout
  title={t('photography.title')}
  description={t('photography.description')}
>
  <article class="photography-gallery">
    <header class="gallery-header">
      <h1>{t('photography.title')}</h1>
      <p>{t('photography.description')}</p>
    </header>

    <div class="photo-grid" id="photoGrid">
      {
        photos.map(photo => (
          <div
            class="photo-item"
            tabindex="0"
            role="button"
            aria-label={photo.alt}
          >
            <PhotoOuterFrame
              src={photo.src}
              alt={photo.alt}
              camera={photo.camera}
              film={photo.film}
            />
          </div>
        ))
      }
    </div>

    <div id="photo-modal" class="modal-overlay" style="display:none;">
      <div class="modal-content">
        <div class="modal-side-text modal-side-left">
          <span class="side-text" id="modal-camera"></span>
        </div>
        <button class="modal-close" id="modal-close" aria-label="Close"
          >&times;</button
        >
        <img src="" alt="" class="modal-image" id="modal-img" />
        <div class="modal-side-text modal-side-right">
          <span class="side-text" id="modal-film"></span>
        </div>
      </div>
    </div>
  </article>
</Layout>

<style>
  /* Remove component-specific styles now handled by PhotoOuterFrame.astro */
  /* Keep only grid, responsive, and general layout styles here. */

  .photography-gallery {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .gallery-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .gallery-header h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .gallery-header p {
    font-size: 1.2rem;
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 0 auto;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1rem;
    margin-bottom: 3rem;
  }
  .photo-item {
    opacity: 1;
    transform: scale(1);
    transition: all 0.3s ease;
    /* Remove grid-row span classes */
  }

  /* Responsive design */
  @media (max-width: 1200px) {
    .photo-grid {
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    }
  }

  @media (max-width: 768px) {
    .photo-grid {
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 0.75rem;
    }

    .gallery-header h1 {
      font-size: 2rem;
    }
  }

  @media (max-width: 480px) {
    .photo-grid {
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 0.5rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('photo-modal');
    const modalImg = document.getElementById('modal-img');
    const modalCamera = document.getElementById('modal-camera');
    const modalFilm = document.getElementById('modal-film');
    const modalClose = document.getElementById('modal-close');

    function openModal(item) {
      const img = item.querySelector('img');
      const camera = item.querySelector(
        '.photo-side-left .side-text'
      ).textContent;
      const film = item.querySelector(
        '.photo-side-right .side-text'
      ).textContent;
      modalImg.src = img.src;
      modalImg.alt = img.alt;
      modalCamera.textContent = camera;
      modalFilm.textContent = film;
      modal.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }

    document.querySelectorAll('.photo-item').forEach(item => {
      item.addEventListener('click', () => openModal(item));
      item.addEventListener('keydown', e => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          openModal(item);
        }
      });
    });

    function closeModal() {
      modal.style.display = 'none';
      document.body.style.overflow = '';
    }

    modalClose.addEventListener('click', closeModal);
    modal.addEventListener('click', e => {
      if (e.target === modal) closeModal();
    });
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && modal.style.display === 'flex') closeModal();
    });
  });
</script>

<style>
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
  }
  .modal-content {
    position: relative;
    background: white;
    padding: 1rem;
    border-radius: 4px;
    max-width: 90vw;
    max-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
  }
  .modal-close {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    background: rgba(0, 0, 0, 0.7);
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: white;
    z-index: 10000;
    padding: 0.5rem;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: background-color 0.2s ease;
  }
  .modal-close:hover {
    background: rgba(0, 0, 0, 0.9);
  }
  .modal-image {
    max-width: 80vw;
    max-height: 80vh;
    object-fit: contain;
    display: block;
  }
  .modal-side-text {
    position: absolute;
    width: 2.5rem;
    display: flex;
    align-items: center;
    height: 100%;
    opacity: 1;
    pointer-events: none;
  }
  .modal-side-left {
    left: 0;
    align-items: end;
    justify-content: right;
  }
  .modal-side-right {
    right: 0;
    align-items: start;
    justify-content: left;
  }
  .side-text {
    display: block;
    color: #222;
    font-size: 1rem;
    font-family: 'Hack', 'Hack Regular', monospace;
    letter-spacing: 0.1em;
    font-weight: 500;
    white-space: nowrap;
    text-align: center;
    user-select: text;
    background: transparent;
    padding: 0;
    margin: 0;
  }
  .modal-side-left .side-text {
    transform: rotate(-90deg) translate(100%, 0);
    transform-origin: bottom right;
  }
  .modal-side-right .side-text {
    transform: rotate(90deg) translate(0, -100%);
    transform-origin: top left;
  }
</style>
