  },
  {
    src: '/images/photography/000032390019.jpg',
    alt: 'Photo 3',
    camera: 'NIKON F3',
    film: 'ILFORD HP5 PLUS',
  },
  {
    src: '/images/photography/000032390021.jpg',
    alt: 'Photo 4',
    camera: 'HASSELBLAD 500C/M',
    film: 'KODAK EKTACHROME 100',
  },
  {
    src: '/images/photography/000032390029.jpg',
    alt: 'Photo 5',
    camera: 'PENTAX K1000',
    film: 'FUJIFILM VELVIA 50',
  },
  {
    src: '/images/photography/000032390031.jpg',
    alt: 'Photo 6',
    camera: 'OLYMPUS OM-1',
    film: 'KODAK TRI-X 400',
  },
  {
    src: '/images/photography/000032390034.jpg',
    alt: 'Photo 7',
    camera: 'LEICA M6',
    film: 'KODAK PORTRA 400',
  },
  {
    src: '/images/photography/000033720004.jpg',
    alt: 'Photo 8',
    camera: 'CANON AE-1',
    film: 'FUJIFILM PRO 400H',
  },
  {
    src: '/images/photography/000033720014.jpg',
    alt: 'Photo 9',
    camera: 'NIKON F3',
    film: 'ILFORD HP5 PLUS',
  },
  {
    src: '/images/photography/000033720016.jpg',
    alt: 'Photo 10',
    camera: 'HASSELBLAD 500C/M',
    film: 'KODAK EKTACHROME 100',
  },
  {
    src: '/images/photography/000033720018.jpg',
    alt: 'Photo 11',
    camera: 'PENTAX K1000',
    film: 'FUJIFILM VELVIA 50',
  },
  {
    src: '/images/photography/000033720033.jpg',
    alt: 'Photo 12',
